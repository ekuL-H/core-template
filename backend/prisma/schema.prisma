generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE MODELS — shared across all workspace types
// ============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  tokenVersion Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core relations
  profile    Profile?
  workspaces WorkspaceUser[]
  settings   Setting[]
  activityLogs ActivityLog[]

  // Module relations (workspace-scoped data links through workspace, but Prisma needs direct user relation)
  watchlists        Watchlist[]
  journals          Journal[]
  datasets          Dataset[]
  brokerConnections BrokerConnection[]
  aiModels          AiModel[]
  workflows         Workflow[]
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  username  String?  @unique
  bio       String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Workspace {
  id           String    @id @default(uuid())
  name         String
  type         String    // 'trading', 'property', etc
  status       String    @default("active") // active, archived, deleted
  archivedAt   DateTime?
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users             WorkspaceUser[]
  watchlists        Watchlist[]
  journals          Journal[]
  datasets          Dataset[]
  brokerConnections BrokerConnection[]
  aiModels          AiModel[]
  invites           WorkspaceInvite[]
}

model WorkspaceUser {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("member") // owner, admin, member, viewer
  isFavourite Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model Setting {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  eventType   String
  description String
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ============================================================================
// TRADING MODULE — models specific to trading workspaces
// ============================================================================

// -- Market data (shared across workspaces, not user-scoped) --

model Symbol {
  id          String   @id @default(uuid())
  name        String   @unique
  assetClass  String
  description String?
  createdAt   DateTime @default(now())

  candles        Candle[]
  watchlistItems WatchlistItem[]
  mappings       SymbolMapping[]
}

model SymbolMapping {
  id           String   @id @default(uuid())
  symbolId     String
  source       String   // e.g. 'icmarkets-mt5'
  sourceSymbol String   // e.g. 'EURUSD'
  createdAt    DateTime @default(now())

  symbol Symbol @relation(fields: [symbolId], references: [id])

  @@unique([symbolId, source])
}

model Candle {
  id        String   @id @default(uuid())
  symbolId  String
  timeframe String   // '1min', '30min', '4h', '1day', etc
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  timestamp DateTime

  symbol Symbol @relation(fields: [symbolId], references: [id])

  @@unique([symbolId, timeframe, timestamp])
}

// -- Broker connections (workspace-scoped) --

model BrokerConnection {
  id            String   @id @default(uuid())
  userId        String
  workspaceId   String
  brokerName    String
  accountNumber String?
  status        String   @default("disconnected") // disconnected, connected, error
  config        Json?    // source, server, etc
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

// -- Watchlists (workspace-scoped) --

model Watchlist {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  items     WatchlistItem[]
}

model WatchlistItem {
  id           String   @id @default(uuid())
  watchlistId  String
  symbolId     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id])
  symbol    Symbol    @relation(fields: [symbolId], references: [id])
}

// -- Journal (workspace-scoped) --

model Journal {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  description String?
  color       String   @default("#3b82f6")
  columns     Json     @default("[]") // column config: [{id, label, type, options?, width}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  entries   JournalEntry[]
}

model JournalEntry {
  id        String   @id @default(uuid())
  journalId String
  rowOrder  Int      @default(0)
  data      Json     @default("{}") // cell values keyed by column id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

// -- AI / ML (workspace-scoped) --

model AiModel {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  description String?
  type        String
  filePath    String?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  workflowSteps WorkflowStep[]
}

model Dataset {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  description String?
  type        String   @default("images") // images, documents, mixed
  color       String   @default("#06b6d4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id])
  workspace Workspace     @relation(fields: [workspaceId], references: [id])
  items     DatasetItem[]
}

model DatasetItem {
  id        String   @id @default(uuid())
  datasetId String
  fileName  String
  filePath  String
  fileType  String   // image/png, image/jpeg, application/pdf, etc
  fileSize  Int
  label     String?
  notes     String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

// -- Automation / Workflows (not yet workspace-scoped, future refactor) --

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id])
  steps WorkflowStep[]
  runs  WorkflowRun[]
}

model WorkflowStep {
  id         String   @id @default(uuid())
  workflowId String
  stepNumber Int
  stepType   String
  config     Json
  onValid    String?
  onInvalid  String?
  aiModelId  String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])
  aiModel  AiModel? @relation(fields: [aiModelId], references: [id])
}

model WorkflowRun {
  id         String    @id @default(uuid())
  workflowId String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    @default("running")

  workflow Workflow         @relation(fields: [workflowId], references: [id])
  logs     WorkflowRunLog[]
}

model WorkflowRunLog {
  id             String   @id @default(uuid())
  workflowRunId  String
  stepNumber     Int
  result         String?
  aiResponse     String?
  screenshotPath String?
  timestamp      DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id])
}

