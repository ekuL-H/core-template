generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        Profile?
  brokerConnections BrokerConnection[]
  watchlists     Watchlist[]
  aiModels       AiModel[]
  workflows      Workflow[]
  journalEntries JournalEntry[]
  activityLogs   ActivityLog[]
  settings       Setting[]
  workspaces     WorkspaceUser[]
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  username  String?  @unique
  bio       String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   WorkspaceUser[]
}

model WorkspaceUser {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("member")
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model BrokerConnection {
  id            String   @id @default(uuid())
  userId        String
  brokerName    String
  accountNumber String?
  status        String   @default("disconnected")
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Symbol {
  id          String   @id @default(uuid())
  name        String   @unique
  assetClass  String
  description String?
  createdAt   DateTime @default(now())

  candles       Candle[]
  watchlistItems WatchlistItem[]
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id])
  items WatchlistItem[]
}

model WatchlistItem {
  id          String   @id @default(uuid())
  watchlistId String
  symbolId    String
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id])
  symbol    Symbol    @relation(fields: [symbolId], references: [id])
}

model Candle {
  id        String   @id @default(uuid())
  symbolId  String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  timestamp DateTime

  symbol Symbol @relation(fields: [symbolId], references: [id])

  @@unique([symbolId, timeframe, timestamp])
}

model AiModel {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  type        String
  filePath    String?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  workflowSteps WorkflowStep[]
}

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id])
  steps WorkflowStep[]
  runs  WorkflowRun[]
}

model WorkflowStep {
  id            String   @id @default(uuid())
  workflowId    String
  stepNumber    Int
  stepType      String
  config        Json
  onValid       String?
  onInvalid     String?
  aiModelId     String?
  createdAt     DateTime @default(now())

  workflow Workflow  @relation(fields: [workflowId], references: [id])
  aiModel  AiModel?  @relation(fields: [aiModelId], references: [id])
}

model WorkflowRun {
  id         String   @id @default(uuid())
  workflowId String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  status     String   @default("running")

  workflow Workflow         @relation(fields: [workflowId], references: [id])
  logs     WorkflowRunLog[]
}

model WorkflowRunLog {
  id            String   @id @default(uuid())
  workflowRunId String
  stepNumber    Int
  result        String?
  aiResponse    String?
  screenshotPath String?
  timestamp     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  direction String
  entryPrice Float
  exitPrice  Float?
  size       Float?
  pnl        Float?
  tradeDate  DateTime?
  notes      String?
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  eventType   String
  description String
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Setting {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}